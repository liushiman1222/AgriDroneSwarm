///|
/// Public demo entry for AgriDroneSwarm.
///
/// This function is called by `cmd/main`.

pub fn demo() -> Unit {
  println("1. Field")
  field_summary()

  println("2. Drone")
  drone_summary()

  println("3. Mission")
  mission_summary()

  println("4. Scheduler")
  scheduler_summary()

  println("5. Weather")
  weather_summary()

  println("6. Sensor")
  sensor_summary()

  println("7. Coverage")
  coverage_summary()

  println("8. Fleet")
  fleet_summary()

  println("9. Maintenance")
  maintenance_summary()

  println("10. Telemetry")
  telemetry_summary()

  println("11. Battery")
  battery_summary()

  println("12. Spray")
  spray_summary()

  println("13. Obstacle")
  obstacle_summary()

  println("14. Geofence")
  geofence_summary()

  println("15. Route")
  route_summary()

  println("16. Payload")
  payload_summary()

  println("17. Path Planning")
  path_planning_summary()

  println("18. Swarm")
  swarm_summary()

  println("19. Control")
  control_summary()

  println("20. Command")
  command_summary()

  println("21. Event Log")
  event_log_summary()
}



///|
/// Print a small agricultural field scenario.
pub fn print_scenario() -> Unit {
  println("Field size: 10 x 10 grid")
  println("Start points: agricultural drones")
  println("Targets: crop inspection points")
  println("Obstacles: trees, irrigation equipment, restricted areas")
}

///|
/// Demonstrate simple swarm coordination.
pub fn demo_swarm() -> Unit {
  println("Drone-1 assigned to crop row A")
  println("Drone-2 assigned to crop row B")
  println("Drone-3 assigned to crop row C")
  println("Coordination rule: keep safe distance and avoid duplicate coverage")
  println("Swarm status: stable")
}

///|
/// Demonstrate a simplified control loop.
pub fn demo_control() -> Unit {
  println("Controller: PID-like correction")
  println("Input: desired waypoint and current drone position")
  println("Output: velocity correction")
  println("Control status: converging")
}
